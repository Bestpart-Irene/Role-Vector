# Copy to .env (gitignored) and fill in. NEVER commit real keys.
#   cp .env.example .env  &&  set -a && . ./.env && set +a

# --- NDIF remote (nnsight on [redacted]'s National Deep Inference Fabric) ---
ROLEVEC_NDIF_REMOTE=1
NDIF_API_KEY=

# --- Claude judge (separate from the extraction model) ---
ANTHROPIC_API_KEY=
ROLEVEC_JUDGE_MODEL=claude-sonnet-4-6

# --- HuggingFace (gated models like Llama need a token) ---
HF_TOKEN=

# --- default extraction model (optional; or pass --model) ---
ROLEVEC_MODEL=

# --- Zotero (shared group library with your teammate) ---
ZOTERO_API_KEY=          # https://www.zotero.org/settings/keys  (give it group read/write)
ZOTERO_GROUP_ID=         # numeric id of your shared group; teammate's shared items live here too
# ZOTERO_USER_ID=        # alternative: personal library (not shared)
